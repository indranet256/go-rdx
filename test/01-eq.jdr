test-eq("float    " 123.0 1.23e2)
test-eq("int      " 12 12)
test-eq("string   " "same" "same")
test-eq("empty tuples" (()1()()) (,1,,) )

var A "Aaa"
test-eq("set()    " ("Aaa" "Aaa") (A A))

test-eq("len(plex)" 3 len {a b c})
test-eq("len(plex)" 3 len({a b c}))
test-eq("len()    " 0 len())
test-eq("len(first)" 1 len 123)

test-all("semicolons" (1 2 3), 1 2 3; 1:2:3; 1:2:3)
test-eq("semicolon2" (@A-1 (1 2 3)), (@A-1 1 2 3;))
test-eq("semicolon3" (@A-1 (1 (2 3))), (@A-1 1 (2 3);))
