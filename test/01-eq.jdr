test("float" 123.0 1.23e2)
test("int" 12 12)
test("string" "same" "same")
test("empty tuples" (()1()()) (,1,,) )

var A "Aaa"
test("set()" ("Aaa" "Aaa") (A A))

test("semicolon1" (1 2 3), 1 2 3;)
test("semicolon2" (1 2 3), 1:2:3;)
test("semicolon3" (1 2 3), 1:2:3)
test("semicolon4" (@A-1 (1 2 3)), (@A-1 1 2 3;))
test("semicolon5" (@A-1 (1 (2 3))), (@A-1 1 (2 3);))
